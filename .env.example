# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/helpme

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Payments (Paystack - optional for MVP)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Maps (Google or Mapbox)
MAPBOX_ACCESS_TOKEN=
